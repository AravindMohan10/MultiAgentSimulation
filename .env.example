# Copy to ".env" in the repo root (gitignored). Loaded automatically by run_episode_groq.py and run_pilot.py via python-dotenv.
#
# Shell exports still work: if GROQ_API_KEY is already set in your environment, it is not overridden.

# Required for Groq-backed runs
GROQ_API_KEY=

# Optional Groq tuning (defaults exist in code / GroqClient)
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_TEMPERATURE=0.1
# GROQ_MAX_TOKENS=256
# GROQ_TIMEOUT_SECONDS=60
# GROQ_JSON_MODE=1
# GROQ_BASE_URL=https://api.groq.com/openai/v1/chat/completions

# Optional: pause between batch API calls
# GROQ_BATCH_SLEEP_SECONDS=0.5
